# Google OAuth - Client ID de Google Cloud Console
# Crear en: https://console.cloud.google.com/ > APIs & Services > Credentials
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# API de Prisma (directorio de profesores)
# Solo usada por el proxy (Vite en dev, nginx en prod). No se expone en el bundle.
PRISMA_API_KEY=your_prisma_api_key

# ── Google Drive Archive ─────────────────────────────────────────────────────
# Archivado automático de fotos de eventos a Google Drive para liberar espacio.
#
# Opción 1: Credenciales como JSON inline (recomendado para producción/PM2)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
#
# Opción 2: Ruta al archivo de credenciales (alternativa)
# GOOGLE_SERVICE_ACCOUNT_PATH=./service-account.json
#
# ID de la carpeta raíz en Google Drive donde se crearán las subcarpetas de eventos.
# Se obtiene de la URL de Drive: https://drive.google.com/drive/folders/{ESTE_ID}
GOOGLE_DRIVE_FOLDER_ID=
#
# Días de antigüedad mínima para que un evento sea elegible para archivado (por defecto: 30)
ARCHIVE_DAYS_THRESHOLD=30
#
# Activar cron automático: archivado el día 1 de cada mes a las 03:00 (true/false)
ARCHIVE_CRON_ENABLED=false
